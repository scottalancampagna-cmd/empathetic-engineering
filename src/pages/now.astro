---
import { getEntry, render } from 'astro:content';
import PreviewLink from '../components/PreviewLink.astro';
import Page from '../layouts/Page.astro';

const entry = await getEntry('pages', 'now');
if (!entry) throw new Error('Now page content not found');
const { Content } = await render(entry);
const { lastUpdated } = entry.data;
---

<Page title="Now" lastUpdated={lastUpdated}>
	<Content components={{ PreviewLink }} />
</Page>
