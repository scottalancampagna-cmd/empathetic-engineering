---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const books = [
	{
		title: "What Got You Here Won't Get You There",
		author: 'Marshall Goldsmith',
		color: '#e63946',
		why: "The habits and behaviors that earned you success can be exactly what's holding you back from the next level. Goldsmith names the specific things high achievers do that quietly undermine them — and most of us are doing at least three of them. This one made me look at myself a lot more honestly.",
	},
	{
		title: 'Think Again',
		author: 'Adam Grant',
		color: '#2a9d8f',
		why: "The ability to change your mind — actually update your beliefs when evidence says you should — is a skill, not a personality trait. Grant convinced me that being confidently wrong and then publicly right is more powerful than never admitting you were wrong in the first place.",
	},
	{
		title: 'Dare to Lead',
		author: 'Brené Brown',
		color: '#e9c46a',
		why: "Everything I believe about leadership is in here somewhere. Vulnerability isn't weakness — it's the thing that actually builds trust. Brown gave language to a lot of things I'd been doing instinctively for years and helped me understand why they worked.",
	},
	{
		title: "Childhood's End",
		author: 'Arthur C. Clarke',
		color: '#457b9d',
		why: "Clarke asks what happens to humanity when we get everything we think we want — and the answer is unsettling in a way that sticks with you for years. It's the book that made me realize science fiction is actually the best lens for thinking about where we're headed.",
	},
	{
		title: 'Earth Abides',
		author: 'George R. Stewart',
		color: '#a8dadc',
		why: "A quiet, devastating post-apocalyptic novel that strips away everything nonessential and asks: what actually matters? Not survival — anyone can survive — but what do you build, and why? One of the most underrated books I've ever read.",
	},
	{
		title: 'The Elegant Universe',
		author: 'Brian Greene',
		color: '#f4a261',
		why: "Greene makes string theory and the fabric of spacetime genuinely beautiful. This is what curiosity looks like at full throttle — a physicist so in love with the elegance of the universe that you can't help catching some of it. It's the reason I'll read physics books forever.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="Scott Campagna — engineering executive, generalist, and the ad hoc Director of Morale everywhere he goes."
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 4em;
			}

			/* ── Profile header ── */
			.profile-header {
				display: flex;
				gap: 2em;
				align-items: flex-start;
				margin-bottom: 2.5em;
			}
			.profile-photo {
				width: 160px;
				height: 160px;
				border-radius: 8px;
				object-fit: cover;
				border: 4px outset #ccc;
				flex-shrink: 0;
			}
			.photo-placeholder {
				width: 160px;
				height: 160px;
				border-radius: 8px;
				background: rgb(var(--gray-light));
				border: 4px outset #ccc;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3em;
				flex-shrink: 0;
				color: rgb(var(--gray));
			}
			.profile-intro h1 {
				font-size: 2rem;
				margin: 0 0 0.15em;
			}
			.profile-intro .role {
				font-size: 1rem;
				color: rgb(var(--gray));
				margin: 0 0 1em;
				font-style: italic;
			}
			.profile-intro p {
				font-size: 0.95rem;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
				margin: 0 0 0.75em;
			}
			.profile-intro p:last-child {
				margin-bottom: 0;
			}

			/* ── Section headings ── */
			.section-title {
				font-size: 1.4rem;
				border-bottom: 3px solid var(--accent-yellow);
				padding-bottom: 0.2em;
				margin: 2.5em 0 1em;
				color: rgb(var(--black));
			}

			/* ── Influential books ── */
			.books-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-bottom: 0.75rem;
			}
			.book-card {
				background: #fff;
				border: 3px outset #ccc;
				padding: 0;
				overflow: hidden;
				display: flex;
				flex-direction: column;
				transition: border-style 0.1s, background 0.15s;
			}
			.book-card:hover {
				border-style: inset;
				background: #fffde7;
			}
			.book-accent {
				height: 5px;
				flex-shrink: 0;
			}
			.book-body {
				padding: 0.85em 1em;
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.15em;
			}
			.book-title {
				font-weight: 700;
				font-size: 0.92rem;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.book-author {
				font-size: 0.78rem;
				color: rgb(var(--gray));
				font-style: italic;
				margin-bottom: 0.5em;
			}
			.book-why {
				font-size: 0.82rem;
				line-height: 1.6;
				color: rgb(var(--gray-dark));
				margin: 0;
			}
			.reading-list-link {
				font-size: 0.85rem;
				color: var(--accent);
				text-decoration: none;
				display: inline-block;
				margin-top: 0.25rem;
			}
			.reading-list-link:hover {
				text-decoration: underline;
			}

			/* ── Media cards grid ── */
			.media-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 1rem;
			}
			.media-card {
				background: #fff;
				border: 3px outset #ccc;
				border-radius: 4px;
				padding: 1em;
				text-decoration: none;
				color: inherit;
				transition: border-style 0.1s, background 0.15s;
				display: flex;
				flex-direction: column;
				gap: 0.4em;
			}
			.media-card:hover {
				border-style: inset;
				background: #fffde7;
			}
			.media-card .card-type {
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
			}
			.media-card .card-title {
				font-size: 0.9rem;
				font-weight: 700;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.media-card .card-meta {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				font-family: 'Courier New', monospace;
				margin-top: auto;
			}

			/* ── Speaking list ── */
			.speaking-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.speaking-list li {
				display: flex;
				flex-direction: column;
				gap: 0.15em;
				padding: 0.75em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.speaking-list li:last-child {
				border-bottom: none;
			}
			.speaking-list .item-title a {
				font-weight: 700;
				color: var(--accent);
				text-decoration: none;
			}
			.speaking-list .item-title a:hover {
				text-decoration: underline;
			}
			.speaking-list .item-venue {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				font-style: italic;
			}

			@media (max-width: 600px) {
				.profile-header {
					flex-direction: column;
					align-items: center;
					text-align: center;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
				.media-grid {
					grid-template-columns: 1fr 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ── Profile header ── -->
			<div class="profile-header">
				<img
					src="/profile.jpg"
					alt="Scott Campagna"
					class="profile-photo"
					onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
				/>
				<span class="photo-placeholder" style="display:none" aria-hidden="true">🧑‍💻</span>

				<div class="profile-intro">
					<h1>Scott Campagna</h1>
					<p class="role">Engineering Executive · Mobile &amp; Emerging Tech · Ad Hoc Director of Morale</p>
					<p>
						I've been the ad hoc Director of Morale everywhere I've gone since I was running summer
						camps in college — and the job description has always been the same: make the hard thing
						a little more fun than it has to be.
					</p>
					<p>
						I'm a generalist by nature. Genuinely curious about almost everything — physics, politics,
						sci-fi, basketball, the way teams actually work, why some ideas spread and others don't.
						I learn quickly and can get reasonably good at most things, but when something grabs me I
						go deeper than most generalists do. I can't help it.
					</p>
					<p>
						Professionally that looks like 15+ years building and scaling engineering organizations
						across three continents — mobile banking, XR/AR/VR, teams from 50 to 250+ people. This
						blog is where I write about the human side of all of it.
					</p>
				</div>
			</div>

			<!-- ── Influential books ── -->
			<h2 class="section-title">📚 Books That Shaped Me</h2>
			<div class="books-grid">
				{
					books.map((book) => (
						<div class="book-card">
							<div class="book-accent" style={`background:${book.color}`} />
							<div class="book-body">
								<span class="book-title">{book.title}</span>
								<span class="book-author">{book.author}</span>
								<p class="book-why">{book.why}</p>
							</div>
						</div>
					))
				}
			</div>
			<a href="/reading" class="reading-list-link">Full reading list →</a>

			<!-- ── Podcast & Media ── -->
			<h2 class="section-title">🎙️ Podcasts &amp; Media</h2>
			<div class="media-grid">
				<a
					href="https://podcasts.apple.com/us/podcast/catalyst-podcast/id1087659707?i=1000686145902"
					target="_blank"
					rel="noopener noreferrer"
					class="media-card"
				>
					<span class="card-type">🎧 Podcast</span>
					<span class="card-title">Putting People in the Right Positions</span>
					<span class="card-meta">Catalyst Podcast · Jan 2025</span>
				</a>

				<a
					href="https://launch.nttdata.com/insights/looking-ahead-the-promise-of-apple-vision-pro-and-visionary-path-ahead-for-ar"
					target="_blank"
					rel="noopener noreferrer"
					class="media-card"
				>
					<span class="card-type">🎧 Podcast</span>
					<span class="card-title">Looking Into the Future: Apple Vision Pro</span>
					<span class="card-meta">Catalyst Podcast · Mar 2024</span>
				</a>

				<a
					href="https://bitrise.io/blog/post/mobile-development-and-delivery-at-scale"
					target="_blank"
					rel="noopener noreferrer"
					class="media-card"
				>
					<span class="card-type">📝 Publication</span>
					<span class="card-title">Mobile Development and Delivery at Scale</span>
					<span class="card-meta">Bitrise Blog · Apr 2024</span>
				</a>
			</div>

			<!-- ── Speaking & Industry ── -->
			<h2 class="section-title">🎤 Speaking &amp; Industry</h2>
			<ul class="speaking-list">
				<li>
					<span class="item-title">
						<a href="#" target="_blank" rel="noopener noreferrer"
							>Mobile Development and Delivery at Scale</a
						>
					</span>
					<span class="item-venue">Mobile DevOps Summit · Featured Speaker · 2024</span>
				</li>
				<li>
					<span class="item-title">Predictions Panel: Mobile DevOps Trends</span>
					<span class="item-venue">Mobile DevOps Panel · Industry Expert · Jan 2023</span>
				</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
