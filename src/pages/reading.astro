---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import booksData from '../data/books.json';

const { books } = booksData;

const reading = books.filter((b) => b.status === 'reading');
const read = books.filter((b) => b.status === 'read');
const want = books.filter((b) => b.status === 'want');

function goodreadsSearchUrl(title: string, author: string) {
	const q = encodeURIComponent(`${title} ${author}`);
	return `https://www.goodreads.com/search?q=${q}`;
}

function formatDate(dateStr: string) {
	if (!dateStr) return null;
	return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const statusLabel: Record<string, string> = {
	reading: '📖 Currently Reading',
	read: '✅ Read',
	want: '🔖 Want to Read',
};

// Cycle through accent colors for spine strips
const spineColors = ['#e63946', '#2a9d8f', '#e9c46a', '#457b9d', '#a8dadc', '#f4a261'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Reading | ${SITE_TITLE}`} description="Books I'm reading, have read, and want to read." />
		<style>
			main {
				max-width: min(960px, calc(100% - 2em));
				width: 100%;
			}

			.page-header {
				text-align: center;
				margin-bottom: 1.5rem;
				padding: 0.75em 1.5em;
				border: 4px double var(--accent);
				background: #fff;
				box-shadow: 5px 5px 0 var(--accent-yellow);
			}
			.page-header h1 {
				font-family: Georgia, 'Times New Roman', serif;
				font-size: 2.5rem;
				color: var(--accent);
				margin: 0;
				text-shadow: 2px 2px 0 var(--accent-yellow);
				letter-spacing: 0.04em;
			}
			.page-header .tagline {
				font-style: italic;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0.2em 0 0;
			}

			.section-title {
				font-family: Georgia, 'Times New Roman', serif;
				font-size: 1.4rem;
				color: var(--accent);
				margin: 2rem 0 1rem;
				padding-bottom: 0.3em;
				border-bottom: 3px double var(--accent);
			}

			.book-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			/* Card with cover image */
			.book-card {
				background: #fff;
				border: 3px outset #ccc;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: row;
				transition: border-style 0.1s, background 0.15s;
				overflow: hidden;
			}
			.book-card:hover {
				border-style: inset;
				background: #fffde7;
			}

			/* Colored spine strip (shown when no cover) */
			.book-spine {
				flex-shrink: 0;
				width: 8px;
			}

			/* Cover thumbnail (shown when coverUrl is set) */
			.book-cover-thumb {
				flex-shrink: 0;
				width: 64px;
				object-fit: cover;
				display: block;
				border-right: 2px solid rgb(var(--gray-light));
			}

			.book-info {
				padding: 0.75em 0.85em;
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.2em;
				min-width: 0;
			}
			.book-title {
				font-weight: bold;
				font-size: 0.95rem;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.book-card:hover .book-title {
				color: var(--accent);
			}
			.book-author {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				font-style: italic;
			}
			.book-notes {
				font-size: 0.78rem;
				color: rgb(var(--gray-dark));
				line-height: 1.4;
				font-style: italic;
				margin-top: 0.3em;
			}
			.book-meta {
				font-family: 'Courier New', monospace;
				font-size: 0.68rem;
				color: rgb(var(--gray));
				margin-top: auto;
				padding-top: 0.4em;
			}

			.empty-section {
				color: rgb(var(--gray));
				font-style: italic;
				font-size: 0.9rem;
			}

			@media (max-width: 720px) {
				.page-header h1 {
					font-size: 1.8rem;
				}
				.book-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>📚 Reading List</h1>
				<p class="tagline">I'm really good at starting books.</p>
			</div>

			{
				[
					{ key: 'reading', list: reading },
					{ key: 'read', list: read },
					{ key: 'want', list: want },
				].map(({ key, list }) => (
					<>
						<h2 class="section-title">{statusLabel[key]}</h2>
						{list.length === 0 ? (
							<p class="empty-section">Nothing here yet.</p>
						) : (
							<div class="book-grid">
								{list.map((book, i) => {
									const href = book.goodreadsUrl || goodreadsSearchUrl(book.title, book.author);
									const spineColor = spineColors[i % spineColors.length];
									return (
										<a class="book-card" href={href} target="_blank" rel="noopener">
											{book.coverUrl ? (
												<img
													class="book-cover-thumb"
													src={book.coverUrl}
													alt={`Cover of ${book.title}`}
													loading="lazy"
												/>
											) : (
												<span class="book-spine" style={`background:${spineColor}`} />
											)}
											<div class="book-info">
												<span class="book-title">{book.title}</span>
												<span class="book-author">{book.author}</span>
												{book.notes && <p class="book-notes">"{book.notes}"</p>}
												<div class="book-meta">
													{book.startDate && (
														<span>Started {formatDate(book.startDate)}</span>
													)}
													{book.finishDate && (
														<span> · Finished {formatDate(book.finishDate)}</span>
													)}
												</div>
											</div>
										</a>
									);
								})}
							</div>
						)}
					</>
				))
			}
		</main>
		<Footer />
	</body>
</html>
