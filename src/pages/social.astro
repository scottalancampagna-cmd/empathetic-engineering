---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { BLUESKY_HANDLE, LINKEDIN_URL, SITE_TITLE } from '../consts';
import linkedinData from '../data/linkedin-highlights.json';

// Fetch Bluesky posts at build time
interface BlueskyAuthor {
	handle: string;
	displayName?: string;
}
interface BlueskyPost {
	uri: string;
	author: BlueskyAuthor;
	record: { text: string; createdAt: string };
	likeCount: number;
	repostCount: number;
	replyCount: number;
}
interface FeedItem {
	post: BlueskyPost;
	reply?: unknown;
	reason?: { $type: string; by: BlueskyAuthor };
}

let bskyItems: FeedItem[] = [];
let bskyError = false;

try {
	const res = await fetch(
		`https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${BLUESKY_HANDLE}&limit=20&filter=posts_no_replies`,
	);
	if (res.ok) {
		const data = await res.json();
		bskyItems = (data.feed as FeedItem[]).slice(0, 8);
	} else {
		bskyError = true;
	}
} catch {
	bskyError = true;
}

function getBskyPostUrl(uri: string, authorHandle: string) {
	// uri format: at://did:.../app.bsky.feed.post/rkey
	const rkey = uri.split('/').pop();
	return `https://bsky.app/profile/${authorHandle}/post/${rkey}`;
}

function formatDate(iso: string) {
	return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const { highlights } = linkedinData;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Social | ${SITE_TITLE}`} description="Follow along on Bluesky and LinkedIn." />
		<style>
			main {
				max-width: min(960px, calc(100% - 2em));
				width: 100%;
			}

			.page-header {
				text-align: center;
				margin-bottom: 1.5rem;
				padding: 0.75em 1.5em;
				border: 4px double var(--accent);
				background: #fff;
				box-shadow: 5px 5px 0 var(--accent-yellow);
			}
			.page-header h1 {
				font-family: Georgia, 'Times New Roman', serif;
				font-size: 2.5rem;
				color: var(--accent);
				margin: 0;
				text-shadow: 2px 2px 0 var(--accent-yellow);
				letter-spacing: 0.04em;
			}
			.page-header .tagline {
				font-style: italic;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0.2em 0 0;
			}

			/* ── Section headers ── */
			.section-title {
				display: flex;
				align-items: center;
				gap: 0.6em;
				font-family: Georgia, 'Times New Roman', serif;
				font-size: 1.4rem;
				color: var(--accent);
				margin: 2rem 0 1rem;
				padding-bottom: 0.3em;
				border-bottom: 3px double var(--accent);
			}

			/* ── Bluesky feed ── */
			.bsky-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.bsky-card {
				background: #fff;
				border: 3px outset #ccc;
				padding: 0.85em 1em;
				display: flex;
				flex-direction: column;
				gap: 0.5em;
				text-decoration: none;
				color: inherit;
				transition: border-style 0.1s, background 0.15s;
			}
			.bsky-card:hover {
				border-style: inset;
				background: #fffde7;
			}
			.bsky-repost-label {
				font-family: 'Courier New', monospace;
				font-size: 0.7rem;
				color: rgb(var(--gray));
				letter-spacing: 0.03em;
			}
			.bsky-text {
				font-size: 0.92rem;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
				flex: 1;
				/* clamp to ~6 lines */
				display: -webkit-box;
				-webkit-line-clamp: 6;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.bsky-meta {
				font-family: 'Courier New', monospace;
				font-size: 0.72rem;
				color: rgb(var(--gray));
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
			}
			.bsky-error {
				background: #fff3cd;
				border: 2px solid var(--accent-yellow);
				padding: 1em;
				font-family: 'Courier New', monospace;
				font-size: 0.85rem;
				color: rgb(var(--gray-dark));
			}
			.bsky-follow {
				display: inline-block;
				margin-top: 0.5rem;
				padding: 0.4em 1em;
				background: #0085ff;
				color: #fff;
				font-weight: bold;
				font-size: 0.85rem;
				text-decoration: none;
				border: 2px outset #0066cc;
				transition: border-style 0.1s;
			}
			.bsky-follow:hover {
				border-style: inset;
				background: #0070dd;
			}

			/* ── LinkedIn section ── */
			.linkedin-profile-card {
				display: flex;
				align-items: center;
				gap: 1.2em;
				background: #fff;
				border: 3px outset #ccc;
				padding: 1em 1.2em;
				margin-bottom: 1.5rem;
				max-width: 480px;
			}
			.linkedin-logo {
				flex-shrink: 0;
				width: 44px;
				height: 44px;
				background: #0077b5;
				border-radius: 6px;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.linkedin-logo svg {
				fill: #fff;
			}
			.linkedin-info {
				flex: 1;
			}
			.linkedin-info strong {
				display: block;
				font-size: 1rem;
			}
			.linkedin-info span {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				font-family: 'Courier New', monospace;
			}
			.linkedin-btn {
				display: inline-block;
				margin-top: 0.4em;
				padding: 0.3em 0.9em;
				background: #0077b5;
				color: #fff;
				font-weight: bold;
				font-size: 0.8rem;
				text-decoration: none;
				border: 2px outset #005885;
				transition: border-style 0.1s;
			}
			.linkedin-btn:hover {
				border-style: inset;
				background: #005885;
			}

			/* ── LinkedIn highlights ── */
			.highlight-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.highlight-card {
				background: #fff;
				border: 3px outset #ccc;
				padding: 0.85em 1em;
				display: flex;
				flex-direction: column;
				gap: 0.4em;
				text-decoration: none;
				color: inherit;
				transition: border-style 0.1s, background 0.15s;
			}
			.highlight-card:hover {
				border-style: inset;
				background: #fffde7;
			}
			.highlight-title {
				font-weight: bold;
				font-size: 0.95rem;
				color: rgb(var(--black));
			}
			.highlight-card:hover .highlight-title {
				color: var(--accent);
			}
			.highlight-summary {
				font-size: 0.88rem;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
			}
			.highlight-date {
				font-family: 'Courier New', monospace;
				font-size: 0.72rem;
				color: rgb(var(--gray));
			}

			@media (max-width: 720px) {
				.page-header h1 {
					font-size: 1.8rem;
				}
				.bsky-grid,
				.highlight-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>📡 Social</h1>
				<p class="tagline">What I'm posting across the web</p>
			</div>

			<!-- ── Bluesky ── -->
			<h2 class="section-title">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 2.163c-5.517 0-10 4.483-10 10s4.483 10 10 10 10-4.483 10-10-4.483-10-10-10zm0 1.8c4.523 0 8.2 3.677 8.2 8.2s-3.677 8.2-8.2 8.2-8.2-3.677-8.2-8.2 3.677-8.2 8.2-8.2zm0 2.4c-2.1 0-4.2 1.26-4.2 3.78 0 2.898 2.52 6.3 4.2 7.602 1.68-1.302 4.2-4.704 4.2-7.602 0-2.52-2.1-3.78-4.2-3.78z"/>
				</svg>
				Bluesky — @{BLUESKY_HANDLE}
			</h2>

			{
				bskyError ? (
					<p class="bsky-error">
						⚠️ Couldn't load Bluesky posts right now. Find me at{' '}
						<a href={`https://bsky.app/profile/${BLUESKY_HANDLE}`} target="_blank" rel="noopener">
							@{BLUESKY_HANDLE}
						</a>
					</p>
				) : bskyItems.length === 0 ? (
					<p class="bsky-error">No posts found yet.</p>
				) : (
					<div class="bsky-grid">
						{bskyItems.map((item) => {
							const post = item.post;
							const isRepost = !!item.reason;
							return (
								<a
									class="bsky-card"
									href={getBskyPostUrl(post.uri, post.author.handle)}
									target="_blank"
									rel="noopener"
								>
									{isRepost && (
										<span class="bsky-repost-label">🔁 Repost · @{post.author.handle}</span>
									)}
									<p class="bsky-text">{post.record.text}</p>
									<div class="bsky-meta">
										<span>📅 {formatDate(post.record.createdAt)}</span>
										{post.likeCount > 0 && <span>❤️ {post.likeCount}</span>}
										{post.repostCount > 0 && <span>🔁 {post.repostCount}</span>}
										{post.replyCount > 0 && <span>💬 {post.replyCount}</span>}
									</div>
								</a>
							);
						})}
					</div>
				)
			}

			<a
				class="bsky-follow"
				href={`https://bsky.app/profile/${BLUESKY_HANDLE}`}
				target="_blank"
				rel="noopener"
			>
				Follow on Bluesky →
			</a>

			<!-- ── LinkedIn ── -->
			<h2 class="section-title" style="margin-top: 3rem;">
				<svg width="22" height="22" viewBox="0 0 16 16" aria-hidden="true">
					<path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
				</svg>
				LinkedIn
			</h2>

			<div class="linkedin-profile-card">
				<div class="linkedin-logo">
					<svg width="26" height="26" viewBox="0 0 16 16" aria-hidden="true">
						<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
					</svg>
				</div>
				<div class="linkedin-info">
					<strong>Scott Campagna</strong>
					<span>Mobile Engineering &amp; Leadership</span>
					<br />
					<a class="linkedin-btn" href={LINKEDIN_URL} target="_blank" rel="noopener">
						View Profile →
					</a>
				</div>
			</div>

			{
				highlights.length > 0 && (
					<div class="highlight-grid">
						{highlights.map((h) => (
							<a class="highlight-card" href={h.url} target="_blank" rel="noopener">
								<span class="highlight-title">{h.title}</span>
								{h.summary && <p class="highlight-summary">{h.summary}</p>}
								{h.date && <span class="highlight-date">📅 {formatDate(h.date)}</span>}
							</a>
						))}
					</div>
				)
			}
		</main>
		<Footer />
	</body>
</html>
