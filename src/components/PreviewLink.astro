---
interface Props {
	href: string;
	image: string;
	alt?: string;
}

const { href, image, alt = 'Preview image' } = Astro.props;
---

<span class="preview-link"
	><a href={href} target="_blank" rel="noopener noreferrer"><slot /></a><button
		class="preview-caret"
		type="button"
		title="Preview"
		aria-expanded="false"
		data-href={href}
		data-image={image}
		data-alt={alt}
		>▶</button><span class="preview-expand" hidden
		><code class="preview-short-url" data-loading="true">Loading…</code><button
			class="preview-thumb-btn"
			type="button"
			aria-label={`Open full preview: ${alt}`}
			><img src={image} alt={alt} class="preview-thumb" /></button
		></span
	></span
>

<script>
	// ---- Lightbox (created once, shared across all PreviewLink instances) ----
	let _lightbox: HTMLElement | null = null;

	function getLightbox(): HTMLElement {
		if (_lightbox) return _lightbox;

		_lightbox = document.createElement('div');
		_lightbox.id = 'preview-lightbox';
		_lightbox.setAttribute('role', 'dialog');
		_lightbox.setAttribute('aria-modal', 'true');
		_lightbox.innerHTML = `
			<div class="lb-backdrop"></div>
			<div class="lb-content">
				<button class="lb-close" aria-label="Close preview">✕</button>
				<img class="lb-img" src="" alt="" />
				<a class="lb-url" href="#" target="_blank" rel="noopener noreferrer"></a>
			</div>
		`;
		document.body.appendChild(_lightbox);

		_lightbox.querySelector('.lb-backdrop')!.addEventListener('click', closeLightbox);
		_lightbox.querySelector('.lb-close')!.addEventListener('click', closeLightbox);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeLightbox();
		});

		return _lightbox;
	}

	function openLightbox(image: string, alt: string, shortUrl: string, href: string) {
		const lb = getLightbox();
		(lb.querySelector('.lb-img') as HTMLImageElement).src = image;
		(lb.querySelector('.lb-img') as HTMLImageElement).alt = alt;
		const urlEl = lb.querySelector('.lb-url') as HTMLAnchorElement;
		urlEl.href = href;
		urlEl.textContent = shortUrl;
		lb.classList.add('open');
		document.body.style.overflow = 'hidden';
	}

	function closeLightbox() {
		_lightbox?.classList.remove('open');
		document.body.style.overflow = '';
	}

	// ---- Caret toggle ----
	document.addEventListener('click', async (e) => {
		const btn = (e.target as Element).closest<HTMLElement>('.preview-caret');
		if (!btn) return;

		const isOpen = btn.getAttribute('aria-expanded') === 'true';
		const expand = btn.nextElementSibling as HTMLElement;

		if (isOpen) {
			expand.hidden = true;
			btn.textContent = '▶';
			btn.setAttribute('aria-expanded', 'false');
		} else {
			expand.hidden = false;
			btn.textContent = '▼';
			btn.setAttribute('aria-expanded', 'true');

			const codeEl = expand.querySelector<HTMLElement>('.preview-short-url');
			if (codeEl?.dataset.loading) {
				const href = btn.dataset.href!;
				try {
					const res = await fetch(`/api/shorten?url=${encodeURIComponent(href)}`);
					const data = await res.json();
					codeEl.textContent = data.shortUrl ?? href;
				} catch {
					codeEl.textContent = href;
				}
				delete codeEl.dataset.loading;
			}
		}
	});

	// ---- Thumbnail → lightbox ----
	document.addEventListener('click', (e) => {
		const thumb = (e.target as Element).closest<HTMLElement>('.preview-thumb-btn');
		if (!thumb) return;

		const expand = thumb.closest<HTMLElement>('.preview-expand');
		const caretBtn = expand?.previousElementSibling as HTMLElement | null;
		if (!caretBtn) return;

		const image = caretBtn.dataset.image!;
		const alt = caretBtn.dataset.alt!;
		const href = caretBtn.dataset.href!;
		const shortUrl = expand?.querySelector('.preview-short-url')?.textContent ?? href;

		openLightbox(image, alt, shortUrl, href);
	});
</script>

<style>
	.preview-link {
		display: inline;
	}
	.preview-caret {
		background: none;
		border: 1px solid var(--accent);
		color: var(--accent);
		font-size: 0.5em;
		padding: 0 3px;
		cursor: pointer;
		border-radius: 2px;
		margin-left: 2px;
		vertical-align: middle;
		line-height: 1.8;
		transition: background 0.15s;
	}
	.preview-caret:hover {
		background: var(--accent);
		color: #fff;
	}
	.preview-expand[hidden] {
		display: none;
	}
	.preview-expand {
		display: block;
		margin-top: 6px;
		margin-bottom: 6px;
		padding: 6px 8px;
		background: rgba(229, 233, 240, 0.7);
		border-left: 3px solid var(--accent);
		border-radius: 0 3px 3px 0;
	}
	.preview-short-url {
		display: block;
		background: none;
		padding: 0;
		font-size: 0.75em;
		color: rgb(var(--gray-dark));
		word-break: break-all;
		margin-bottom: 8px;
	}
	.preview-thumb-btn {
		background: none;
		border: none;
		padding: 0;
		cursor: zoom-in;
		display: block;
	}
	.preview-thumb {
		max-width: 240px;
		max-height: 180px;
		width: auto;
		height: auto;
		border-radius: 4px;
		border: 1px solid rgba(0, 0, 0, 0.1);
		display: block;
		transition: opacity 0.15s;
	}
	.preview-thumb-btn:hover .preview-thumb {
		opacity: 0.85;
	}

	/* Lightbox — :global because it's appended to <body> outside this component */
	:global(#preview-lightbox) {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 9999;
	}
	:global(#preview-lightbox.open) {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	:global(.lb-backdrop) {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.8);
	}
	:global(.lb-content) {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		padding: 20px;
		max-width: 90vw;
		max-height: 90vh;
	}
	:global(.lb-close) {
		position: absolute;
		top: -8px;
		right: -8px;
		background: #fff;
		border: none;
		border-radius: 50%;
		width: 32px;
		height: 32px;
		font-size: 1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}
	:global(.lb-img) {
		max-width: 100%;
		max-height: 75vh;
		width: auto;
		height: auto;
		border-radius: 6px;
		display: block;
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
	}
	:global(.lb-url) {
		color: #fff;
		font-size: 0.8rem;
		word-break: break-all;
		text-align: center;
		opacity: 0.85;
	}
	:global(.lb-url:hover) {
		opacity: 1;
	}
</style>
