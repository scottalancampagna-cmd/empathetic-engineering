---
interface Props {
	href: string;
	[key: string]: unknown;
}

const { href } = Astro.props;
---

<span class="caret-link"
	><a href={href} target="_blank" rel="noopener noreferrer"><slot /></a><button
		class="caret-btn"
		type="button"
		title="Show short URL"
		aria-expanded="false"
		data-href={href}
		>▶</button><span class="url-display" hidden
		><code class="short-url" data-loading="true">Loading…</code></span
	></span
>

<script>
	document.addEventListener('click', async (e) => {
		const btn = (e.target as Element).closest<HTMLElement>('.caret-link > .caret-btn');
		if (!btn) return;

		const isOpen = btn.getAttribute('aria-expanded') === 'true';
		const display = btn.nextElementSibling as HTMLElement;

		if (isOpen) {
			display.hidden = true;
			btn.textContent = '▶';
			btn.setAttribute('aria-expanded', 'false');
		} else {
			display.hidden = false;
			btn.textContent = '▼';
			btn.setAttribute('aria-expanded', 'true');

			const codeEl = display.querySelector<HTMLElement>('.short-url');
			if (codeEl?.dataset.loading) {
				const href = btn.dataset.href!;
				try {
					const res = await fetch(`/api/shorten?url=${encodeURIComponent(href)}`);
					const data = await res.json();
					codeEl.textContent = data.shortUrl ?? href;
				} catch {
					codeEl.textContent = href;
				}
				delete codeEl.dataset.loading;
			}
		}
	});
</script>

<style>
	.caret-link {
		display: inline;
	}
	.caret-btn {
		background: none;
		border: 1px solid var(--accent);
		color: var(--accent);
		font-size: 0.5em;
		padding: 0 3px;
		cursor: pointer;
		border-radius: 2px;
		margin-left: 2px;
		vertical-align: middle;
		line-height: 1.8;
		transition: background 0.15s;
	}
	.caret-btn:hover {
		background: var(--accent);
		color: #fff;
	}
	.url-display[hidden] {
		display: none;
	}
	.url-display {
		display: block;
		font-size: 0.75em;
		padding: 3px 6px;
		margin-top: 2px;
		background: rgba(229, 233, 240, 0.7);
		border-left: 3px solid var(--accent);
		border-radius: 0 3px 3px 0;
	}
	.short-url {
		background: none;
		padding: 0;
		color: rgb(var(--gray-dark));
		word-break: break-all;
	}
</style>
